PORT=3000
LOG_LEVEL=info
API_PROXY_TARGET=http://127.0.0.1:3000
ANYALPHA_PUBLIC_URL=https://www.anyalpha.com
DATABASE_URL=

# Privy auth. VITE_PRIVY_APP_ID is safe for the browser bundle.
# PRIVY_APP_SECRET is server-side only; never expose it through Vite/client code.
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Telegram Phase 1 alerts.
# Create the bot with @BotFather, add it as an admin to your alert channel,
# then use either a public channel username like @AnyAlphaAlerts or a channel id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=@AnyAlphaAlerts
TELEGRAM_BOT_USERNAME=anyalphaterminalbot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-api-domain.com/api/telegram/webhook
TELEGRAM_BOT_BANNER_PATH=assets/telegram-bot-banner.jpg

# Keep live publishing off until filters are trusted.
ALERTS_AUTO_PUBLISH=false

# Phase 2 provider inputs and enrichment.
# Keep enrichment small on free tiers; listings enrich only the top N rows.
MARKET_ENRICHMENT_LIMIT=6
MARKET_PROVIDER_TIMEOUT_MS=1800
MARKET_DETAIL_PROVIDER_TIMEOUT_MS=1800
DEXSCREENER_TIMEOUT_MS=6000
MARKET_LIST_CACHE_TTL_MS=12000
MARKET_LIST_STALE_CACHE_TTL_MS=180000
MARKET_LIST_LIGHT_CACHE_TTL_MS=20000
MARKET_LIST_LIGHT_STALE_CACHE_TTL_MS=300000
MARKET_SEARCH_CACHE_TTL_MS=15000
MARKET_SEARCH_STALE_CACHE_TTL_MS=120000
MARKET_DETAIL_CACHE_TTL_MS=6000
MARKET_DETAIL_STALE_CACHE_TTL_MS=300000
MARKET_SIGNALS_CACHE_TTL_MS=15000
MARKET_SIGNALS_STALE_CACHE_TTL_MS=120000
MARKET_UNIVERSE_CACHE_TTL_MS=120000
MARKET_UNIVERSE_STALE_CACHE_TTL_MS=600000
REDIS_URL=
REDIS_PRIVATE_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false
CACHE_PREFIX=anyalpha

# Mobula uses https://api.mobula.io when MOBULA_API_KEY is set, otherwise demo-api for local testing.
MOBULA_API_KEY=
MOBULA_API_BASE_URL=
MOBULA_PULSE_CACHE_TTL_MS=5000
MOBULA_PULSE_STALE_CACHE_TTL_MS=30000

# Optional Bitquery enrichment for low-latency Trading Tokens snapshots.
BITQUERY_API_KEY=
BITQUERY_API_URL=https://streaming.bitquery.io/graphql
BITQUERY_TIMEOUT_MS=1800
BITQUERY_CACHE_TTL_MS=3000
BITQUERY_STALE_CACHE_TTL_MS=45000

# Trading execution.
# Jupiter is used for Solana wallet-signed swaps. Keep this server-side only.
JUPITER_API_KEY=
JUPITER_SWAP_API_BASE_URL=https://api.jup.ag/swap/v1
JUPITER_TOKENS_API_BASE_URL=https://api.jup.ag/tokens/v2
SOLANA_RPC_URL=
INFURA_API_KEY=
INFURA_API_KEY_SECRET=
INFURA_PROJECT_ID=
LIFI_API_KEY=
LIFI_API_BASE_URL=https://li.quest/v1
ETHEREUM_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_AUTH_HEADER=
MORALIS_API_KEY=
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_ID=
ALCHEMY_WEBHOOK_ID_BSC=
ALCHEMY_WEBHOOK_ID_POLYGON=
ALCHEMY_WEBHOOK_ID_OPTIMISM=
ALCHEMY_NOTIFY_AUTH_TOKEN=
ALCHEMY_WEBHOOK_SIGNING_KEY=
ALCHEMY_METADATA_LIMIT=8
ALCHEMY_DISABLED=false

# Provider webhook registration uses PUBLIC_API_BASE_URL or RAILWAY_PUBLIC_DOMAIN to build public HTTPS endpoints.
PUBLIC_API_BASE_URL=

# Optional local-only fallback. Production should use provider-specific validation above.
WALLET_TRACKER_WEBHOOK_SECRET=
WALLET_TRACKER_ALLOW_SHARED_SECRET_FALLBACK=false
ANYALPHA_ADMIN_SECRET=
ANYALPHA_BUNDLE_ALERTS_ENABLED=true
ANYALPHA_BUNDLE_AUTO_ANALYSIS=true
ANYALPHA_BUNDLE_AUTO_LIMIT=3
ANYALPHA_BUNDLE_AUTO_COOLDOWN_MS=60000
ANYALPHA_BUNDLE_AUTO_MAX_AGE_MINUTES=360
ANYALPHA_BUNDLE_AUTO_LAUNCH_WINDOW_MINUTES=12
ANYALPHA_BUNDLE_AUTO_MIN_LAUNCH_BUYS=3
ANYALPHA_BUNDLE_FUNDING_TRACE_LIMIT=50
ANYALPHA_BUNDLE_EXIT_MONITOR=true
ANYALPHA_BUNDLE_EXIT_MONITOR_LIMIT=15
ANYALPHA_BUNDLE_EXIT_MONITOR_COOLDOWN_MS=90000
ANYALPHA_BUNDLE_EXIT_ALERTS_ENABLED=true

# X/Twitter Track. X webhooks require CRC plus x-twitter-webhooks-signature validation.
X_BEARER_TOKEN=
X_CONSUMER_SECRET=
X_STREAM_ENABLED=false
# Optional server-side query overrides for the public crypto timeline.
X_CRYPTO_TIMELINE_QUERY=
X_CRYPTO_TIMELINE_LIMIT=50

# Public wallet discovery / Watcher indexing
WALLET_DISCOVERY_ENABLED=false
WALLET_DISCOVERY_RUN_ON_START=true
WALLET_DISCOVERY_INTERVAL_MS=600000
WALLET_DISCOVERY_CHAINS=solana,base
WALLET_DISCOVERY_MAX_WALLETS_PER_CHAIN=8
WALLET_DISCOVERY_BACKFILL_LIMIT=20
WALLET_DISCOVERY_SOLANA_SIGNATURE_LIMIT=16
WALLET_DISCOVERY_EVM_BLOCK_LOOKBACK=3
WALLET_DISCOVERY_WEBHOOK_PUBLIC_LIMIT=250
WALLET_DISCOVERY_SOLANA_PROGRAM_IDS=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4,JUP4Fb2cqiRUcaTHdrPC8h2gNsA2ETXiPDD33WcGuJB
WALLET_DISCOVERY_BASE_ROUTER_ADDRESSES=0xcF77a3Ba9A5CA399B7c97c74d54e5bE8cE1fE8F,0x6fF5693b99212Da76ad316178A184AB56D299b43
WALLET_DISCOVERY_ETHEREUM_ROUTER_ADDRESSES=0xEf1c6E67703c7BD7107eed8303Fbe6EC2554BF6B,0x7a250d5630b4cf539739df2c5dacb4c659f2488d

# Pusher enables instant browser alerts. Leave blank to safely fall back to stored notifications only.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Browser Web Push uses VAPID keys. Public key is safe for subscription handshakes;
# private key stays server-side only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@anyalpha.fun

# Privy authentication
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=
