{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack pnpm install --no-frozen-lockfile",
  "buildCommand": "corepack pnpm run vercel:build",
  "outputDirectory": "artifacts/bantah/dist/public",
  "functions": {
    "api/**/*.mjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/.*|assets/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
